---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Projetos</div>
  </div>

  <div class="divider my-0"></div>

  <HorizontalCard
    title="ElectroCodeOS - Gestão de Assistência Técnica"
    img="/appelectrocode.png"
    desc="SaaS full-stack robusto para gestão completa de serviços e financeiro em produção. Implementa autenticação JWT, controle de acesso granular e orquestração de infraestrutura com Docker Compose."
    url="https://github.com/erascardsilva/ElectrocodeOS"
    marketingUrl="https://www.electrocode.com.br/electrocodeos"
    badge="FEATURED"
    tags={["React", "Node.js", "MySQL", "Docker Compose", "JWT", "Nginx", "API REST"]}
  />

  <div class="divider my-0"></div>

  <HorizontalCard
    title="radioGO - Internet Radio & Local Media Player"
    img="/radiogo.png"
    desc="Media Center híbrido de alto desempenho. Combina streaming global de rádio online, extração de áudio do YouTube e reprodução de mídia local com uma interface moderna. Disponível na Snap Store e Microsoft Store."
    url="https://github.com/erascardsilva/radio"
    snapUrl="https://snapcraft.io/radiogo"
    msStoreUrl="https://apps.microsoft.com/detail/9N439CZ8F24F"
    badge="OPEN SOURCE"
    tags={["Go", "Wails", "JavaScript", "HTML5", "Vite"]}
  />

  <div class="divider my-0"></div>

  <HorizontalCard
    title="Clonar Mídia - Ferramenta de Clonagem de Disco"
    img="/clonarmidia.png"
    desc="Ferramenta profissional de alto desempenho para clonagem de discos e partições no Linux. Com uso global consolidado (presente em 67 países) e centenas de dispositivos ativos semanalmente na Snap Store, oferece interface elegante para operações complexas de hardware de baixo nível. Suporta recursos avançados de clonagem e recuperação de dados."
    url="https://github.com/erascardsilva/clonarMidia"
    snapUrl="https://snapcraft.io/clonarmidia"
    badge="OPEN SOURCE"
    tags={["Go", "Wails", "Svelte", "Linux", "Snapcraft", "Node.js", "TypeScript", "Hardware low-level"]}
  />

  <div class="divider my-0"></div>

  <HorizontalCard
    title="Monte Curriculum - Gerador de Currículos Premium"
    img="/mont-curriculum.png"
    desc="Eleve sua carreira profissional com currículos premium de alto impacto. Aplicação desktop moderna que permite criar, importar e gerenciar currículos através de um assistente inteligente de 7 etapas com interface moderna. — Disponível na Snap Store e para Windows."
    url="https://github.com/erascardsilva/mont_curriculum"
    snapUrl="https://snapcraft.io/mont-curriculum"
    badge="OPEN SOURCE"
    tags={["Go", "Wails", "Svelte", "Vite", "TypeScript", "Snapcraft"]}
  />

  <div class="divider my-0"></div>

  <HorizontalCard
    title="PontoCrz - Gerador de Gráficos para Ponto Cruz"
    img="/pontocrz.png"
    desc="Projeto Open Source que converte imagens em gráficos de ponto cruz usando a paleta oficial DMC. — Disponível na Snap Store e Microsoft Store."
    url="https://github.com/erascardsilva/pontoCrz"
    snapUrl="https://snapcraft.io/ponto-crz"
    msStoreUrl="https://apps.microsoft.com/detail/9nbhbw02gmck?cid=DevShareMCLPCS&hl=pt-BR&gl=BR"
    badge="OPEN SOURCE"
    tags={["Go", "Wails", "React", "TypeScript", "Image Processing", "Snapcraft"]}
  />

  <div class="divider my-0"></div>

  <HorizontalCard
    title="Agente IA - Assistente Multimodal Desktop"
    img="/agenteia.png"
    desc="Projeto Open Source de interface rápida e local para produtividade com IA. — Disponível na Snap Store."
    url="https://github.com/erascardsilva/agenteIA"
    snapUrl="https://snapcraft.io/agenteia"
    badge="OPEN SOURCE"
    tags={["Go", "Wails", "Svelte", "SQLite", "LLM APIs", "Web Speech API"]}
  />

  <div class="divider my-0"></div>

  <HorizontalCard
    title="Atualiza GO - Gerenciador de Atualizações Linux"
    img="/atualizago.png"
    desc="Projeto Open Source de manutenção para Linux que detecta a distro e gerencia atualizações de pacotes e limpeza de sistema. — Disponível na Snap Store."
    url="https://github.com/erascardsilva/atualiza_go"
    snapUrl="https://snapcraft.io/atualiza-go"
    badge="OPEN SOURCE"
    tags={["Go", "Wails", "JavaScript", "Linux System", "Bash", "Polkit (pkexec)"]}
  />

  <div class="divider my-0"></div>

  <HorizontalCard
    title="Site da empresa ElectroCode"
    img="/electrocode.png"
    desc="Site institucional desenvolvido em HTML, CSS e JavaScript, hospedado na VPS da empresa."
    url="https://electrocode.com.br#"
    tags={["HTML", "CSS", "JavaScript", "VPS", "Nginx"]}
  />

  <div class="divider my-0"></div>

  <HorizontalCard
    title="Site VMI Informática"
    img="/siteVMI.png"
    desc="Site em HTML CSS e Javascript já o aplicativo de Ordem de Serviço de equipamentos da empresa app em PHP com banco de dados Mysql , o cliente acessa o app pelo site."
    url="https://www.vmi-informatica.com.br/#"
    tags={["HTML", "CSS", "JavaScript", "PHP", "MySQL"]}
  />

  <div class="divider my-0"></div>

  <HorizontalCard
    title="APP de Ordem de Serviço"
    img="/OS.png"
    desc="App de cadastro de clientes, equipamentos e controle financeiro, escrito em PHP com banco de dados MySQL. Possui funcionalidade de pré-cadastro online de equipamentos pelo cliente."
    url="https://vmi-informatica.com.br/os/index.php/os"
    tags={["PHP", "MySQL", "Bootstrap", "jQuery", "PhpMyAdmin"]}
  />

  <div class="divider my-0"></div>

  <HorizontalCard
    title="App ConXtract"
    img="/contract.png"
    desc="ConXtract em desenvolvimento: Um aplicativo para contratos imobiliários, utilizando as tecnologias Golang, React e DynamoDB, hospedado na AWS. Em breve link"
    tags={["React", "Javascript", "Golang", "DynamoDB", "AWS", "Lambda", "EC2", "S3"]}
  />

  <div class="divider my-0"></div>

  <HorizontalCard
    title="Pagina de Login, Cadastro e recuperação"
    img="/marcenaria.png"
    desc="Contribuição no desenvolvimento de páginas de autenticação em projeto PHP Laravel, incluindo fluxo de login, cadastro e recuperação de senha."
    url="https://marcenariadigital.com/login"
    tags={["PHP", "MySQL", "Bootstrap", "Laravel"]}
  />

  <HorizontalCard
    title="Cadastro Igreja"
    img="/proIgreja.png"
    desc="O aplicativo foi desenvolvido utilizando as tecnologias Node.js, Express e SQLite3. Ele é utilizado em um computador local da igreja e está hospedado em um servidor próprio, utilizando Docker. Opera sem depender de conexão com a internet."
    url="https://github.com/erascardsilva/church-app-project"
    tags={["Node.js", "Express", "SQLite3", "Docker"]}
  />

  <div class="divider my-0"></div>

  <HorizontalCard
    title="Portfólio"
    img="/curriculo.png"
    desc="Portfólio em NODE | template Astro."
    url="https://github.com/erascardsilva/curriculo"
  />

  <div class="divider my-0"></div>
</BaseLayout>
