---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Projetos</div>
  </div>

  <div class="divider my-0"></div>

  <HorizontalCard
    title="ElectroCodeOS - Gestão de Assistência Técnica"
    img="/appelectrocode.png"
    desc="SaaS full-stack robusto para gestão completa de serviços e financeiro em produção. Implementa autenticação JWT, controle de acesso granular e orquestração de infraestrutura com Docker Compose."
    url="https://github.com/erascardsilva/ElectrocodeOS"
    badge="FEATURED"
  />
  <ul class="list-disc md:columns-5 columns-2 mx-6 mb-6">
    <li>React</li>
    <li>Node.js</li>
    <li>MySQL</li>
    <li>Docker Compose</li>
    <li>JWT</li>
    <li>Nginx</li>
    <li>API REST</li>
  </ul>

  <div class="divider my-0"></div>

  <HorizontalCard
    title="Clonar Mídia - Ferramenta de Clonagem de Disco"
    img="/clonarmidia.png"
    desc="Ferramenta profissional de alto desempenho para clonagem de discos e partições no Linux. Desenvolvida com Go, Wails e Svelte, oferece uma interface elegante para operações complexas de hardware de baixo nível. Suporta recursos avançados de clonagem e recuperação de dados (TestDisk, PhotoRec, fsck), utilizando um modelo de distribuição híbrido (Snap e instaladores nativos)."
    url="https://github.com/erascardsilva/clonarMidia"
    badge="OPEN SOURCE"
  />
  <ul class="list-disc md:columns-5 columns-2 mx-6 mb-6">
    <li>Go</li>
    <li>Wails</li>
    <li>Svelte</li>
    <li>Linux</li>
    <li>Snapcraft</li>
    <li>Node.js</li>
    <li>TypeScript</li>
    <li>Hardware low-level</li>
  </ul>

  <div class="divider my-0"></div>

  <HorizontalCard
    title="Monte Curriculum - Gerador de Currículos Premium"
    img="/mont-curriculum.png"
    desc="Eleve sua carreira profissional com currículos premium de alto impacto. Aplicação desktop moderna que permite criar, importar e gerenciar currículos através de um assistente inteligente de 7 etapas com interface glassmorphism. — Disponível na Snap Store e para Windows."
    url="https://github.com/erascardsilva/mont_curriculum"
    badge="OPEN SOURCE"
  />
  <ul class="list-disc md:columns-5 columns-2 mx-6 mb-6">
    <li>Go</li>
    <li>Wails</li>
    <li>Svelte</li>
    <li>Vite</li>
    <li>TypeScript</li>
    <li>Snapcraft</li>
  </ul>

  <div class="divider my-0"></div>

  <HorizontalCard
    title="PontoCrz - Gerador de Gráficos para Ponto Cruz"
    img="/pontocrz.png"
    desc="Projeto Open Source que converte imagens em gráficos de ponto cruz usando a paleta oficial DMC. — Disponível na Snap Store."
    url="https://github.com/erascardsilva/pontoCrz"
    badge="OPEN SOURCE"
  />
  <ul class="list-disc md:columns-5 columns-2 mx-6 mb-6">
    <li>Go</li>
    <li>Wails</li>
    <li>React</li>
    <li>TypeScript</li>
    <li>Image Processing</li>
    <li>Snapcraft</li>
  </ul>

  <div class="divider my-0"></div>

  <HorizontalCard
    title="Agente IA - Assistente Multimodal Desktop"
    img="/agenteia.png"
    desc="Projeto Open Source de interface rápida e local para produtividade com IA. — Disponível na Snap Store."
    url="https://github.com/erascardsilva/agenteIA"
    badge="OPEN SOURCE"
  />
  <ul class="list-disc md:columns-5 columns-2 mx-6 mb-6">
    <li>Go</li>
    <li>Wails</li>
    <li>Svelte</li>
    <li>SQLite</li>
    <li>LLM APIs</li>
    <li>Web Speech API</li>
  </ul>

  <div class="divider my-0"></div>

  <HorizontalCard
    title="Atualiza GO - Gerenciador de Atualizações Linux"
    img="/atualizago.png"
    desc="Projeto Open Source de manutenção para Linux que detecta a distro e gerencia atualizações de pacotes e limpeza de sistema. — Disponível na Snap Store."
    url="https://github.com/erascardsilva/atualiza_go"
    badge="OPEN SOURCE"
  />
  <ul class="list-disc md:columns-5 columns-2 mx-6 mb-6">
    <li>Go</li>
    <li>Wails</li>
    <li>JavaScript</li>
    <li>Linux System</li>
    <li>Bash</li>
    <li>Polkit (pkexec)</li>
  </ul>

  <div class="divider my-0"></div>

  <HorizontalCard
    title="Site da empresa ElectroCode"
    img="/electrocode.png"
    desc="Site institucional desenvolvido em HTML, CSS e JavaScript, hospedado na VPS da empresa."
    url="https://electrocode.com.br#"
  />
  <ul class="list-disc md:columns-5 columns-2 mx-6 mb-6">
    <li>HTML</li>
    <li>CSS</li>
    <li>JavaScript</li>
    <li>VPS</li>
    <li>Nginx</li>
  </ul>

  <div class="divider my-0"></div>

  <HorizontalCard
    title="Site VMI Informática"
    img="/siteVMI.png"
    desc="Site em HTML CSS e Javascript já o aplicativo de Ordem de Serviço de equipamentos da empresa app em PHP com banco de dados Mysql , o cliente acessa o app pelo site."
    url="https://www.vmi-informatica.com.br/#"
  />
  <ul class="list-disc md:columns-5 columns-2 mx-6 mb-6">
    <li>HTML</li>
    <li>CSS</li>
    <li>JavaScript</li>
    <li>PHP</li>
    <li>MySQL</li>
  </ul>

  <div class="divider my-0"></div>

  <HorizontalCard
    title="APP de Ordem de Serviço"
    img="/OS.png"
    desc="App de cadastro de clientes , equipamentos e controle financeiro,  escrito em PHP com banco de dados Mysql feito opção para o cliente se cadastrar online e a possibilidade de cadstrar equipamentos antes e enviar "
    url="https://vmi-informatica.com.br/os/index.php/os"
  />
  <ul class="list-disc md:columns-5 columns-2 mx-6 mb-6">
    <li>PHP</li>
    <li>MySQL</li>
    <li>Bootstrap</li>
    <li>jQuery</li>
    <li>PhpMyAdmin</li>
  </ul>

  <div class="divider my-0"></div>

  <HorizontalCard
    title="App ConXtract"
    img="/contract.png"
    desc="ConXtract em desenvolvimento: Um aplicativo para contratos imobiliários, utilizando as tecnologias Golang, React e DynamoDB, hospedado na AWS. Em breve link"
  />
  <ul class="list-disc md:columns-5 columns-2 mx-6 mb-6">
    <li>React</li>
    <li>Javascript</li>
    <li>Golang</li>
    <li>DynamoDB</li>
    <li>AWS</li>
    <li>Lambda</li>
    <li>EC2</li>
    <li>S3</li>
  </ul>

  <div class="divider my-0"></div>

  <HorizontalCard
    title="Pagina de Login, Cadastro e recuperação"
    img="/marcenaria.png"
    desc="Neste serviço trabalhei durante alguns meses e contribui com pagina de login cadastro e recuperação de senha, o projeto é em PHP Laravel com banco de dados Mysql."
    url="https://marcenariadigital.com/login"
  />
  <ul class="list-disc md:columns-5 columns-2 mx-6 mb-6">
    <li>PHP</li>
    <li>MySQL</li>
    <li>Bootstrap</li>
  </ul>

  <HorizontalCard
    title="Cadastro Igreja"
    img="/proIgreja.png"
    desc="O aplicativo foi desenvolvido utilizando as tecnologias Node.js, Express e SQLite3. Ele é utilizado em um computador local da igreja e está hospedado em um servidor próprio, utilizando Docker. Opera sem depender de conexão com a internet."
    url="https://github.com/erascardsilva/church-app-project"
  />
  <ul class="list-disc md:columns-5 columns-2 mx-6 mb-6">
    <li>Node.js</li>
    <li>Express</li>
    <li>SQLite3</li>
    <li>Docker</li>
  </ul>

  <div class="divider my-0"></div>

  <HorizontalCard
    title="Portfólio"
    img="/curriculo.png"
    desc="Portfólio em NODE | template Astro."
    url="https://github.com/erascardsilva/curriculo"
  />

  <div class="divider my-0"></div>
</BaseLayout>
