---
const { title, img, desc, url, badge, tags, snapUrl, target = "_blank" } = Astro.props;
import { Image } from "astro:assets";
const tag_url = url ? url.split("/").slice(0, -1).join("/") + "/tag" : "";
---

<div class="rounded-lg bg-base-100 hover:shadow-xl transition ease-in-out hover:scale-[102%]">
  <div class="hero-content flex-col md:flex-row">
    {img && (
      <a href={url} target={target} class="flex-none">
        <Image
          src={img}
          width={750}
          height={422}
          format="webp"
          alt={title}
          class="max-w-full md:max-w-[13rem] rounded-lg"
        />
      </a>
    )}
    <div class="grow w-full">
      <h1 class="text-xl font-bold">
        <a href={url} target={target}>{title}</a>
        {badge && <div class="badge badge-secondary mx-2">{badge}</div>}
      </h1>
      <p class="py-1 text-1xl text-justify">{desc}</p>
      <div class="card-actions justify-end mt-2 items-center">
        {snapUrl && (
          <a href={snapUrl} target="_blank" class="btn btn-outline btn-sm btn-primary">
            Get it from Snap Store
          </a>
        )}
        <a href={url} target={target} class="btn btn-outline btn-sm">
          GitHub
        </a>
        {tags &&
          tags.map((tag) => (
            <div class="badge badge-outline">{tag}</div>
          ))}
      </div>
    </div>
  </div>
</div>
