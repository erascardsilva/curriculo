---
const { title, img, desc, url, badge, tags, snapUrl, marketingUrl, msStoreUrl, playStoreUrl, target = "_blank" } = Astro.props;
import { Image } from "astro:assets";
const tag_url = url ? url.split("/").slice(0, -1).join("/") + "/tag" : "";
---

<div class="rounded-lg bg-base-100 hover:shadow-xl transition ease-in-out hover:scale-[102%]">
  <div class="hero-content flex-col md:flex-row">
    {img && (
      <a href={url} target={target} class="flex-none">
        <Image
          src={img}
          width={750}
          height={422}
          format="webp"
          alt={title}
          class="max-w-full md:max-w-[13rem] rounded-lg"
        />
      </a>
    )}
    <div class="grow w-full">
      <h1 class="text-xl font-bold">
        <a href={url} target={target}>{title}</a>
        {badge && <div class="badge badge-secondary mx-2">{badge}</div>}
      </h1>
      <p class="py-1 text-1xl text-justify">{desc}</p>
      <div class="flex flex-wrap gap-4 mt-4 items-center justify-between w-full">
        <div class="flex flex-wrap gap-1">
          {tags &&
            tags.map((tag) => (
              <div class="badge badge-outline text-xs py-2">{tag}</div>
            ))}
        </div>
        <div class="flex flex-wrap gap-2 justify-end">
          {marketingUrl && (
            <a href={marketingUrl} target="_blank" class="flex items-center gap-2 px-3 py-1.5 bg-[#111] text-white rounded-lg border border-gray-700 hover:bg-[#222] transition-all h-[44px] min-w-[140px] hover:scale-105 shadow-md">
              <svg class="w-6 h-6 text-gray-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="2" y1="12" x2="22" y2="12"></line>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
              </svg>
              <div class="flex flex-col text-left">
                <span class="text-[9px] leading-tight text-gray-400 font-semibold uppercase tracking-wider">Página Oficial</span>
                <span class="text-sm font-bold leading-tight">Produto</span>
              </div>
            </a>
          )}
          {snapUrl && (
            <a href={snapUrl} target="_blank" class="flex items-center gap-2 px-3 py-1.5 bg-[#111] text-white rounded-lg border border-gray-700 hover:bg-[#222] transition-all h-[44px] min-w-[140px] hover:scale-105 shadow-md">
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="#E95420">
                <path d="M12 2L2 7l10 5 10-5-10-5zm0 7.5l-10-5V17l10 5 10-5V4.5l-10 5z"/>
              </svg>
              <div class="flex flex-col text-left">
                <span class="text-[9px] leading-tight text-gray-400 font-semibold uppercase tracking-wider">Obter na</span>
                <span class="text-sm font-bold leading-tight">Snap Store</span>
              </div>
            </a>
          )}
          {msStoreUrl && (
            <a href={msStoreUrl} target="_blank" class="flex items-center gap-2 px-3 py-1.5 bg-[#111] text-white rounded-lg border border-gray-700 hover:bg-[#222] transition-all h-[44px] min-w-[140px] hover:scale-105 shadow-md">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path fill="#f35325" d="M1 1h10v10H1z"/>
                <path fill="#81bc06" d="M12 1h10v10H12z"/>
                <path fill="#05a6f0" d="M1 12h10v10H1z"/>
                <path fill="#ffba08" d="M12 12h10v10H12z"/>
              </svg>
              <div class="flex flex-col text-left">
                <span class="text-[9px] leading-tight text-gray-400 font-semibold uppercase tracking-wider">Baixar da</span>
                <span class="text-sm font-bold leading-tight">Microsoft Store</span>
              </div>
            </a>
          )}
          {playStoreUrl && (
            <a href={playStoreUrl} target="_blank" class="flex items-center gap-2 px-3 py-1.5 bg-[#111] text-white rounded-lg border border-gray-700 hover:bg-[#222] transition-all h-[44px] min-w-[140px] hover:scale-105 shadow-md">
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none">
                <path d="M4 2.45v19.1c0 .8.88 1.29 1.56.86L21.31 12.86c.61-.37.61-1.35 0-1.72L5.56 1.59C4.88 1.16 4 1.65 4 2.45z" fill="#00e676"/>
              </svg>
              <div class="flex flex-col text-left">
                <span class="text-[9px] leading-tight text-gray-400 font-semibold uppercase tracking-wider">Disponível no</span>
                <span class="text-sm font-bold leading-tight">Google Play</span>
              </div>
            </a>
          )}
          {url && url !== "#" && (
            <a href={url} target={target} class="flex items-center gap-2 px-3 py-1.5 bg-[#111] text-white rounded-lg border border-gray-700 hover:bg-[#222] transition-all h-[44px] min-w-[140px] hover:scale-105 shadow-md">
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="#ffffff">
                <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.416 22 12c0-5.523-4.477-10-10-10z"/>
              </svg>
              <div class="flex flex-col text-left">
                <span class="text-[9px] leading-tight text-gray-400 font-semibold uppercase tracking-wider">{url.includes("github.com") ? "Ver código no" : "Acessar"}</span>
                <span class="text-sm font-bold leading-tight">{url.includes("github.com") ? "GitHub" : "Aplicação"}</span>
              </div>
            </a>
          )}
        </div>
      </div>
    </div>
  </div>
</div>
